{
  "name": "my-app",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "exports": {
    "./entities/*": {
      "types": "./dist/entities/*.d.ts",
      "default": "./dist/entities/*.js"
    },
    "./logic/*": {
      "types": "./dist/logic/*.d.ts",
      "default": "./dist/logic/*.js"
    },
    "./react/*": {
      "types": "./dist/react/*.d.ts",
      "default": "./dist/react/*.js"
    }
  },
  "scripts": {
    "build:types": "tspc -b",
    "build:client": "vite build --config vite.client.config.ts",
    "build:server": "vite build --config vite.server.config.ts",
    "build": "yarn build:types && yarn build:server && yarn build:client",
    "dev:types": "tspc -b --watch --preserveWatchOutput",
    "dev:client": "vite --config vite.client.config.ts",
    "dev:server": "vite build --watch --config vite.server.config.ts",
    "dev": "concurrently -n types,server,client -c blue,green,magenta \"yarn dev:types\" \"yarn dev:server\" \"yarn dev:client\""
  },
  "keywords": [],
  "author": "Olmo del Corral",
  "license": "MIT",
  "dependencies": {
    "@altea/altea": "0.0.1",
    "@altea/altea-auth": "0.0.1",
    "quote-transformer": "0.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "vite": "^7.0.0"
  }
}
